# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
BASE_URL=http://localhost:3000

# ─── MCP Authentication ───────────────────────────────────────────────────────
# Clients must send: Authorization: Bearer <MCP_API_KEY>
# Generate a strong random value: openssl rand -hex 32
MCP_API_KEY=change-me-to-a-strong-random-secret

# Used for OAuth state/session protection. Generate a strong random value.
SESSION_SECRET=change-me-to-a-strong-session-secret

# ─── Slack OAuth 2.0 ──────────────────────────────────────────────────────────
# Create an app at https://api.slack.com/apps
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Must match the redirect URL in your Slack app settings
SLACK_REDIRECT_URI=http://localhost:3000/auth/slack/callback

# Optional: pre-existing xoxb- bot token for single-workspace local usage
# SLACK_BOT_TOKEN=xoxb-your-bot-token

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
